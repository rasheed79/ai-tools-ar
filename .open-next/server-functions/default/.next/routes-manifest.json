{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/alt/[slug]",
      "regex": "^/alt/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/alt/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/best/[useCase]",
      "regex": "^/best/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPuseCase": "nxtPuseCase"
      },
      "namedRegex": "^/best/(?<nxtPuseCase>[^/]+?)(?:/)?$"
    },
    {
      "page": "/compare/[pair]",
      "regex": "^/compare/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPpair": "nxtPpair"
      },
      "namedRegex": "^/compare/(?<nxtPpair>[^/]+?)(?:/)?$"
    },
    {
      "page": "/tools/[slug]",
      "regex": "^/tools/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/tools/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/compare",
      "regex": "^/compare(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/compare(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/tools",
      "regex": "^/tools(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tools(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": [
    {
      "source": "/ادوات/:slug",
      "destination": "/tools/:slug",
      "regex": "^/ادوات(?:/([^/]+?))(?:/)?$"
    },
    {
      "source": "/مقارنة/:pair",
      "destination": "/compare/:pair",
      "regex": "^/مقارنة(?:/([^/]+?))(?:/)?$"
    },
    {
      "source": "/افضل-ادوات/:useCase",
      "destination": "/best/:useCase",
      "regex": "^/افضل-ادوات(?:/([^/]+?))(?:/)?$"
    },
    {
      "source": "/:slug-بديل",
      "destination": "/alt/:slug",
      "regex": "^(?:/([^/]+?))-بديل(?:/)?$"
    }
  ]
}