# ============================================================
# LOCAL DEVELOPMENT — copy to .env.local (never commit .env.local)
# ============================================================

# Supabase — get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyYOUR_ANON_KEY

# Resend — get from: https://resend.com/api-keys (free: 100 emails/day)
RESEND_API_KEY=re_your_key_here
# Optional: Resend Audience ID for contact list (get from Resend dashboard → Audiences)
# If not set, sends welcome email directly instead
RESEND_AUDIENCE_ID=

# ============================================================
# WHERE TO SET EACH VAR:
# 1. Local dev    → .env.local (this file, renamed)
# 2. Production   → Cloudflare Pages dashboard:
#                   Settings → Environment variables
# 3. GitHub CI    → repo Settings → Secrets and variables → Actions
#                   (needed for supabase-ping.yml keep-alive)
# ============================================================
